    { "text": "42", "skip": true },
    { "text": "-3.14", "skip": true },
    { "text": "+5", "skip": true },
    { "text": ".5", "skip": true },
    { "text": "5.", "skip": true },
    { "text": "1.5e10", "skip": true },
