{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TS/PHP translation pipeline contract",
  "description": "Values both pipelines must agree on: the skip predicate, the placeholder scheme, and the AI batching limits. Asserted by contract.test.ts and ContractTest.php so a one-sided edit fails fast.",
  "type": "object",
  "required": ["skipCases", "placeholder", "batching"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "skipCases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["text", "skip"],
        "additionalProperties": false,
        "properties": {
          "text": {
            "type": "string"
          },
          "skip": {
            "type": "boolean"
          }
        }
      }
    },
    "placeholder": {
      "type": "object",
      "required": ["format", "indexBase"],
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string",
          "pattern": "\\{n\\}"
        },
        "indexBase": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "batching": {
      "type": "object",
      "required": ["maxBatchSize", "maxSizePerBatch"],
      "additionalProperties": false,
      "properties": {
        "maxBatchSize": {
          "type": "integer",
          "minimum": 1
        },
        "maxSizePerBatch": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
