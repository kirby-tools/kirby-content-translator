{
  "name": "kirby-content-translator",
  "type": "module",
  "version": "3.10.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "mprocs",
    "build": "kirbyup src/panel/index.ts",
    "build:playground": "PLAYGROUND=true pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"src/panel/**\" --write",
    "test": "vitest",
    "test:types": "tsc --noEmit",
    "release": "pnpm run build && bumpp --all --execute \"npx zx scripts/pre-release.mjs\" && zx scripts/post-release.mjs"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.72",
    "@ai-sdk/google": "^3.0.65",
    "@ai-sdk/mistral": "^3.0.31",
    "@ai-sdk/openai": "^3.0.54",
    "@ai-sdk/provider": "^3.0.9",
    "@antfu/eslint-config": "^8.2.0",
    "@kirby-tools/licensing": "^0.8.0",
    "@sindresorhus/slugify": "^3.0.0",
    "@types/node": "^25.6.0",
    "@unocss/eslint-plugin": "^66.6.8",
    "ai": "^6.0.170",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.1",
    "jiti": "^2.6.1",
    "kirby-types": "^1.4.9",
    "kirbyup": "^3.4.1",
    "kirbyuse": "^1.3.1",
    "mprocs": "^0.9.2",
    "ofetch": "^1.5.1",
    "p-all": "^5.0.1",
    "p-map": "^7.0.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "ufo": "^1.6.4",
    "unocss": "^66.6.8",
    "utilful": "^2.5.3",
    "vite": "~6.3.7",
    "vitest": "^4.1.5",
    "vue": "^2.7.16",
    "yaml": "^2.8.3",
    "zod": "^4.4.1",
    "zx": "^8.8.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ]
  }
}
