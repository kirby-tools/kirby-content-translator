{
  "name": "kirby-content-translator",
  "type": "module",
  "version": "3.11.2",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "dev": "mprocs",
    "build": "kirbyup src/panel/index.ts",
    "build:playground": "PLAYGROUND=true pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"src/panel/**\" --write",
    "test": "vitest",
    "test:types": "tsc --noEmit",
    "release": "pnpm run build && bumpp --all --execute \"npx zx scripts/pre-release.mjs\" && zx scripts/post-release.mjs"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.97",
    "@ai-sdk/google": "^3.0.94",
    "@ai-sdk/mistral": "^3.0.50",
    "@ai-sdk/openai": "^3.0.85",
    "@ai-sdk/provider": "^3.0.14",
    "@antfu/eslint-config": "^9.1.0",
    "@kirby-tools/licensing": "^0.8.0",
    "@sindresorhus/slugify": "^3.0.0",
    "@types/node": "^26.1.1",
    "@unocss/eslint-plugin": "^66.7.5",
    "ai": "^6.0.228",
    "bumpp": "^11.1.0",
    "eslint": "^10.7.0",
    "jiti": "^2.7.0",
    "kirby-types": "^1.6.0",
    "kirbyup": "^3.4.1",
    "kirbyuse": "^1.3.1",
    "mprocs": "^0.9.6",
    "ofetch": "^1.5.1",
    "p-all": "^5.0.1",
    "p-map": "^7.0.5",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "ufo": "^1.6.4",
    "unocss": "^66.7.5",
    "utilful": "^2.5.3",
    "vite": "~6.3.7",
    "vitest": "^4.1.10",
    "vue": "^2.7.16",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "zx": "^8.8.5"
  }
}
